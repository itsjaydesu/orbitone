# Copy this file to `.env.local` for local development.
#
# Video export is intentionally disabled in production deployments.
# To enable the in-browser export flow on a development machine, set
# both flags below to `true`.
#
# Leave these unset or `false` in production.
NEXT_PUBLIC_ENABLE_VIDEO_EXPORT=false
ENABLE_VIDEO_EXPORT=false

# Optional: base URL used by `pnpm export:library`.
# Defaults to `http://127.0.0.1:3000` when unset.
ORBITONE_EXPORT_BASE_URL=http://127.0.0.1:3000

# Optional: explicit Chrome / Chromium executable path for Playwright-based
# export scripts. Uncomment and set this only if auto-detection fails.
# PLAYWRIGHT_CHROME_EXECUTABLE=/absolute/path/to/chrome
